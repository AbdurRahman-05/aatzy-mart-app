generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model activity_logs {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?   @db.Uuid
  action     String    @db.VarChar(255)
  details    String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model buyers {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String?     @unique @db.Uuid
  location    String?     @db.VarChar(255)
  preferences Json?
  created_at  DateTime?   @default(now()) @db.Timestamp(6)
  updated_at  DateTime?   @default(now()) @db.Timestamp(6)
  users       users?      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inquiries   inquiries[]
}

model categories {
  id               Int          @id @default(autoincrement())
  name             String       @db.VarChar(100)
  description      String?
  slug             String       @unique @db.VarChar(100)
  parent_id        Int?
  image_url        String?      @db.VarChar(512)
  created_at       DateTime?    @default(now()) @db.Timestamp(6)
  updated_at       DateTime?    @default(now()) @db.Timestamp(6)
  categories       categories?  @relation("categoriesTocategories", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_categories categories[] @relation("categoriesTocategories")
  products         products[]
  services         services[]

  @@index([parent_id], map: "idx_categories_parent")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model favorites {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?   @db.Uuid
  product_id String?   @db.Uuid
  service_id String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamp(6)
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services   services? @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, product_id], map: "unique_user_product")
  @@unique([user_id, service_id], map: "unique_user_service")
  @@index([user_id], map: "idx_favorites_user")
}

model inquiries {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  buyer_id            String?               @db.Uuid
  supplier_id         String?               @db.Uuid
  product_id          String?               @db.Uuid
  service_id          String?               @db.Uuid
  title               String                @db.VarChar(255)
  description         String
  quantity            Decimal               @db.Decimal(12, 2)
  unit                String                @db.VarChar(50)
  location            String                @db.VarChar(255)
  images              String[]
  status              String?               @default("New") @db.VarChar(50)
  quoted_price        Decimal?              @db.Decimal(10, 2)
  delivery_status     String?               @default("Pending") @db.VarChar(50)
  gst_percent         Decimal?              @default(18.00) @db.Decimal(5, 2)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  updated_at          DateTime?             @default(now()) @db.Timestamp(6)
  buyers              buyers?               @relation(fields: [buyer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products            products?             @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  services            services?             @relation(fields: [service_id], references: [id], onUpdate: NoAction)
  suppliers           suppliers?            @relation(fields: [supplier_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inquiry_status_logs inquiry_status_logs[]

  @@index([buyer_id], map: "idx_inquiries_buyer")
  @@index([status], map: "idx_inquiries_status")
  @@index([supplier_id], map: "idx_inquiries_supplier")
}

model inquiry_status_logs {
  id                 String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  inquiry_id         String?    @db.Uuid
  status             String     @db.VarChar(50)
  notes              String?
  changed_by_user_id String?    @db.Uuid
  created_at         DateTime?  @default(now()) @db.Timestamp(6)
  users              users?     @relation(fields: [changed_by_user_id], references: [id], onUpdate: NoAction)
  inquiries          inquiries? @relation(fields: [inquiry_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model material_news {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title        String    @db.VarChar(255)
  content      String
  category     String?   @db.VarChar(100)
  published_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)
}

model notifications {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?   @db.Uuid
  title      String    @db.VarChar(255)
  body       String
  payload    Json?
  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_notifications_unread", where: raw("(is_read = false)"))
  @@index([user_id], map: "idx_notifications_user")
}

model products {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  supplier_id     String?     @db.Uuid
  category_id     Int?
  name            String      @db.VarChar(255)
  description     String
  specifications  Json?
  images          String[]
  status          String?     @default("Pending") @db.VarChar(50)
  rejected_reason String?
  price_per_unit  Decimal?    @default(0.00) @db.Decimal(10, 2)
  unit_type       String?     @default("Bag") @db.VarChar(50)
  cost_price      Decimal?    @default(0.00) @db.Decimal(10, 2)
  created_at      DateTime?   @default(now()) @db.Timestamp(6)
  updated_at      DateTime?   @default(now()) @db.Timestamp(6)
  deleted_at      DateTime?   @db.Timestamp(6)
  favorites       favorites[]
  inquiries       inquiries[]
  categories      categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  suppliers       suppliers?  @relation(fields: [supplier_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category_id], map: "idx_products_category")
  @@index([status], map: "idx_products_status")
  @@index([supplier_id], map: "idx_products_supplier")
}

model roles {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users[]
}

model services {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  supplier_id     String?     @db.Uuid
  category_id     Int?
  name            String      @db.VarChar(255)
  description     String
  images          String[]
  status          String?     @default("Pending") @db.VarChar(50)
  rejected_reason String?
  created_at      DateTime?   @default(now()) @db.Timestamp(6)
  updated_at      DateTime?   @default(now()) @db.Timestamp(6)
  deleted_at      DateTime?   @db.Timestamp(6)
  favorites       favorites[]
  inquiries       inquiries[]
  categories      categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  suppliers       suppliers?  @relation(fields: [supplier_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category_id], map: "idx_services_category")
  @@index([status], map: "idx_services_status")
  @@index([supplier_id], map: "idx_services_supplier")
}

model suppliers {
  id                                 String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                            String?     @unique @db.Uuid
  company_name                       String      @db.VarChar(255)
  business_type                      String      @db.VarChar(100)
  description                        String?
  location                           String      @db.VarChar(255)
  gst_number                         String?     @unique @db.VarChar(15)
  website                            String?     @db.VarChar(255)
  logo_url                           String?     @db.VarChar(512)
  images                             String[]
  is_approved                        Boolean?    @default(false)
  approved_by                        String?     @db.Uuid
  approved_at                        DateTime?   @db.Timestamp(6)
  created_at                         DateTime?   @default(now()) @db.Timestamp(6)
  updated_at                         DateTime?   @default(now()) @db.Timestamp(6)
  deleted_at                         DateTime?   @db.Timestamp(6)
  materials_providing                String?     @db.VarChar(512)
  inquiries                          inquiries[]
  products                           products[]
  services                           services[]
  users_suppliers_approved_byTousers users?      @relation("suppliers_approved_byTousers", fields: [approved_by], references: [id], onUpdate: NoAction)
  users_suppliers_user_idTousers     users?      @relation("suppliers_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([is_approved], map: "idx_suppliers_approved")
  @@index([user_id], map: "idx_suppliers_user")
}

model users {
  id                                     String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                                   String                @db.VarChar(255)
  email                                  String?               @unique @db.VarChar(255)
  phone                                  String                @unique @db.VarChar(20)
  password_hash                          String                @db.VarChar(255)
  role_id                                Int?
  is_active                              Boolean?              @default(true)
  created_at                             DateTime?             @default(now()) @db.Timestamp(6)
  updated_at                             DateTime?             @default(now()) @db.Timestamp(6)
  deleted_at                             DateTime?             @db.Timestamp(6)
  activity_logs                          activity_logs[]
  buyers                                 buyers?
  favorites                              favorites[]
  inquiry_status_logs                    inquiry_status_logs[]
  notifications                          notifications[]
  suppliers_suppliers_approved_byTousers suppliers[]           @relation("suppliers_approved_byTousers")
  suppliers_suppliers_user_idTousers     suppliers?            @relation("suppliers_user_idTousers")
  roles                                  roles?                @relation(fields: [role_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([phone], map: "idx_users_phone")
  @@index([role_id], map: "idx_users_role")
}
