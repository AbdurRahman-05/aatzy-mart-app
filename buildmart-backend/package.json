{
  "name": "buildmart-backend",
  "version": "1.0.0",
  "description": "BuildMart B2B Marketplace API Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npx prisma generate && npm run admin:install && npm run admin:build",
    "admin:install": "npm install --prefix admin",
    "admin:build": "npm run build --prefix admin",
    "admin:dev": "npm run dev --prefix admin"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^7.8.0"
  }
}
